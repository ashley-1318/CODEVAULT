# ============================================================
# VAULT MVP — Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# --- LLM Provider ---
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# --- Observability (LangSmith free tier) ---
# Get your free API key from: https://smith.langchain.com/
LANGSMITH_API_KEY=lsv2_your_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=vault-mvp

# --- PostgreSQL ---
POSTGRES_URL=postgresql+asyncpg://vault:vaultpass@postgres:5432/vaultdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=vault
POSTGRES_PASSWORD=vaultpass
POSTGRES_DB=vaultdb

# --- Neo4j Graph Database ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vaultpass123

# --- MinIO Object Storage ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vaultadmin
MINIO_SECRET_KEY=vaultadmin123
MINIO_BUCKET=vault-uploads
MINIO_USE_SSL=false

# --- Ollama (Local Embeddings) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
